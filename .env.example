# 复制为 .env 后填写本地真实配置；不要提交真实 .env。

# 两种运行模式共用
BITE_ID=replace_with_your_bitbrowser_id
GC_PAGE_URL_MARKERS=["ppzh.jd.com"]

# backfill_engine.py 使用
TASKS_CONFIG='[
    {"card":1,"start":"2025-01-01","end":"2025-01-31","chunk_days":1}
]'

# daily_engine.py 使用
WORKER_COUNT=4
MAX_ATTEMPTS=5
TARGET_DATE_OFFSET_DAYS=1
# 可选：填写后忽略日期偏移并统一执行指定日期；留空则按偏移计算。
TARGET_DATE=
COOKIE_DIR=C:\Users\Administrator\Desktop\COOKIE
TASK_URL=https://datatoolcenter.com/web/dateCenter.html?activeName=selfitemkeyShop&menuplat=%E5%B7%A5%E4%BD%9C%E5%8F%B0
DAILY_TASKS='[
    {"card":2},
    {"card":3},
    {"card":4},
    {"card":5},
    {"card":6}
]'
PLATFORMS='[
    {"name":"京东品牌主页（商智）",
    "home_url":"https://ppzh.jd.com/brand/homePage/index.html",
    "login_url_markers":["login"],
    "cookie_key":"京东品牌主页",
    "file_prefix":"jd_cookies",
    "cookie_enabled":true}
]'
