# 复制为 notify_agent.env 后填写真实配置；不要提交真实 webhook。

# dailyfill 根目录。留空时默认使用 notify_agent.env 所在目录。
CLIENTS_ROOT=

# 飞书自定义机器人 webhook。
FEISHU_WEBHOOK_URL=

# 飞书标题；单机部署时可写成 “Daily RPA 巡检｜6号机”。
NOTIFY_TITLE=Daily RPA 巡检

# 通知窗口与频率。
NOTIFY_START_TIME=09:00
NOTIFY_END_TIME=18:00
NOTIFY_INTERVAL_MINUTES=30

# 未完成任务下，如果 daily_run.log 超过该分钟数没有更新，则追加“疑似故障”。
STALE_LOG_MINUTES=20

# 文件名保持和 daily_engine.py 当前产物一致；除非后续改名，否则不用动。
DAILY_RESULTS_FILENAME=daily_results.jsonl
DAILY_LOG_FILENAME=daily_run.log
