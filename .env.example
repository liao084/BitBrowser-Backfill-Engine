# 复制为 .env 后填写本地真实配置；不要提交真实 .env。

# 两种运行模式共用
BITE_ID="replace_with_bitbrowser_id"
GC_PAGE_URL_MARKERS=["replace_with_business_url_marker"]
CUSTOMER_NAME="replace_with_customer_name"
REPORT_READY_TIME=10:30

# backfill_engine.py 使用
TASKS_CONFIG='[
    {"card":1,"start":"2025-01-01","end":"2025-01-31","chunk_days":1}
]'

# daily_engine.py 使用
WORKER_COUNT=1
# 每个 daily 单日任务最多执行次数；失败尝试会立即放回共享队列尾部。
MAX_ATTEMPTS=5
TARGET_DATE_OFFSET_DAYS=1
# 可选：填写后忽略日期偏移并统一执行指定日期；留空则按偏移计算。
TARGET_DATE=
COOKIE_DIR=C:\Users\你的用户名\Desktop\COOKIE
TASK_URL=https://datatoolcenter.com/web/dateCenter.html?activeName=selfitemkeyShop&menuplat=%E5%B7%A5%E4%BD%9C%E5%8F%B0
DAILY_TASKS='[
    {"card":1}
]'
PLATFORMS='[
    {
        "name":"replace_with_platform_name",
        "home_url":"https://example.com/",
        "login_url_markers":["login"],
        "cookie_key":"replace_with_cookie_key",
        "file_prefix":"replace_with_cookie_file_prefix",
        "cookie_enabled":true
    }
]'

# 常用平台配置片段，仅供复制；daily_engine.py 不读取这个字段。
